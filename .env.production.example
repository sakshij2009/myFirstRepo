# Production environment variables
# Set VITE_CONTINUE_URL to the URL used in email invite links (e.g. https://app.yourdomain.com)
VITE_CONTINUE_URL=
# Optional: explicitly set the Firebase authDomain to fallback to (e.g. famforeveradmin.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=famforeveradmin.firebaseapp.com
